# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=generated

# ===========================================
# AI Service API Keys - AlphoGenAI Mini
# ===========================================

# Video backend (V1)
# - mock: default for local/CI (uploads a 1s dummy mp4 to Supabase)
# - modal: production backend (Modal serverless GPU)
VIDEO_BACKEND=mock

# Modal video service (required when VIDEO_BACKEND=modal)
MODAL_VIDEO_ENDPOINT_URL=https://your-modal-web-endpoint.example.com

# ===========================================
# Music Configuration
# ===========================================
# Music files stored in Supabase Storage under assets/music/

# ===========================================
# Webhook Configuration (Optional)
# ===========================================
WEBHOOK_URL=https://your-domain.com/api/webhooks/video-complete
WEBHOOK_SECRET=your-webhook-secret-key

# ===========================================
# Worker Configuration
# ===========================================
MAX_RETRIES=3
RETRY_DELAY=5
JOB_TIMEOUT=3600
POLL_INTERVAL=10


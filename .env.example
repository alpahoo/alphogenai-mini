# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Admin and Storage
ADMIN_TOKEN=change-me-long-and-random
SUPABASE_STORAGE_BUCKET=music

# ===========================================
# AI Service API Keys - AlphoGenAI Mini
# ===========================================

# Qwen (Alibaba Cloud) - LLM for script generation
QWEN_API_KEY=sk-qwen-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# WAN Image - AI image generation
WAN_IMAGE_API_KEY=wan-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WAN_IMAGE_API_BASE=https://api.wan.ai/v1

# Pika - AI video generation
PIKA_API_KEY=pika-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIKA_API_BASE=https://api.pika.art/v1

# ElevenLabs - Text-to-speech
ELEVENLABS_API_KEY=el-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1

# Remotion - Video rendering service
REMOTION_RENDERER_URL=http://localhost:3001

# ===========================================
# Webhook Configuration
# ===========================================
WEBHOOK_URL=https://your-domain.com/api/webhooks/video-complete
WEBHOOK_SECRET=your-webhook-secret-key

# ===========================================
# Worker Configuration
# ===========================================
MAX_RETRIES=3
RETRY_DELAY=5
JOB_TIMEOUT=3600

# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===========================================
# AI Service API Keys - AlphoGenAI Mini
# ===========================================

# Runway gen4_turbo - Video generation (5 credits/sec vs 40 for veo3 = 87.5% cheaper)
RUNWAY_API_KEY=sk-runway-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNWAY_API_BASE=https://api.dev.runwayml.com/v1
RUNWAY_MODEL=gen4_turbo

# Qwen (Mock) - Script generation
QWEN_MOCK_ENABLED=true

# OpenAI - Prompt generation for Runway Gen-4
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Music Configuration
# ===========================================
# Music files stored in Supabase Storage under assets/music/

# ===========================================
# Webhook Configuration (Optional)
# ===========================================
WEBHOOK_URL=https://your-domain.com/api/webhooks/video-complete
WEBHOOK_SECRET=your-webhook-secret-key

# ===========================================
# Worker Configuration
# ===========================================
MAX_RETRIES=3
RETRY_DELAY=5
JOB_TIMEOUT=3600
POLL_INTERVAL=10

# ===========================================
# Assembly Service (Reuse-Only Mode)
# ===========================================
# For admin-only direct assembly/download of existing clips without Runway calls
RENDER_WORKER_URL=https://your-worker.onrender.com
ASSEMBLER_SHARED_SECRET=your-long-random-secret-here
NO_STORAGE_UPLOAD=true
MUSIC_SOURCE=external
CLIP_DURATION=10

# ===========================================
# PYTHON WORKER DEPLOYMENT (Render.com)
# ===========================================
# The following variables must be configured in Render.com Dashboard
# when deploying the Python worker for video job processing:
#
# REQUIRED:
#   - SUPABASE_URL (same as NEXT_PUBLIC_SUPABASE_URL above)
#   - SUPABASE_SERVICE_ROLE_KEY (use service_role key, NOT anon key)
#   - RUNWAY_API_KEY (your Runway ML API key from https://runwayml.com)
#
# OPTIONAL (with defaults):
#   - RUNWAY_API_BASE=https://api.dev.runwayml.com/v1
#   - RUNWAY_MODEL=gen4_turbo
#   - QWEN_MOCK_ENABLED=true
#   - WEBHOOK_URL=https://your-domain.com/api/webhooks/video-complete
#   - WEBHOOK_SECRET=your-webhook-secret
#   - MAX_RETRIES=3
#   - RETRY_DELAY=5
#   - JOB_TIMEOUT=3600
#   - POLL_INTERVAL=10
#   - NO_STORAGE_UPLOAD=true
#   - MUSIC_SOURCE=external
#   - ASSEMBLER_SHARED_SECRET=your-long-random-secret
#   - CLIP_DURATION=10
#
# See WORKER_DEPLOYMENT.md for detailed deployment instructions

# ===========================================
# AUDIO AMBIENCE MODULE (NEW)
# ===========================================

# Stable Video Infinity (SVI) on Runpod
SVI_ENDPOINT_URL=                    # Set after deploying SVI (tools/deploy_svi.py)
SVI_MODE=film                        # film|shot
SVI_FPS=24
SVI_RES=1920x1080
SVI_DURATION_SEC=60
SVI_SEED=42

# Audio Service Configuration
AUDIO_BACKEND_URL=                   # Set after deploying audio-service
AUDIO_MODE=auto                      # auto|off
AUDIO_PRIORITY=audioldm2             # difffoley|audioldm2
AUDIO_DIFFFOLEY=false                # Enable Diff-Foley (experimental)
AUDIO_MOCK=false                     # Set to true for development without GPU
CLAP_ENABLE=true                     # Enable CLAP audio-text scoring

# Cloudflare R2 Storage (Optional - will use Supabase Storage if not configured)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name

# Budget Guards
MAX_CONCURRENCY=1                    # Maximum concurrent jobs
MAX_RUNTIME_PER_JOB=720              # Maximum runtime per job in seconds (12 minutes)
DAILY_BUDGET_ALERT_EUR=30            # Alert threshold for daily spending
DAILY_BUDGET_HARDCAP_EUR=50          # Hard cap for daily spending

# Storage
SUPABASE_BUCKET=generated            # Supabase Storage bucket for generated assets

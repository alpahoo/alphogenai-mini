# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Modal (GPU pipeline)
# ===========================================
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
MODAL_WEBHOOK_SECRET=your-webhook-secret
# After `modal deploy`, this is the URL printed in the terminal
# e.g. https://your-user--alphogenai-v2-webhook.modal.run
MODAL_WEBHOOK_URL=https://your-modal-webhook-url.modal.run

# ===========================================
# Video Generation
# ===========================================
VIDEO_DURATION_SEC=8
VIDEO_FPS=24
VIDEO_RESOLUTION=1280x720

# ===========================================
# Cloudflare R2 (used by worker for video upload)
# ===========================================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=alphogenai-assets
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ===========================================
# Optional
# ===========================================
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

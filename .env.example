# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Modal (GPU pipeline)
# ===========================================
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
MODAL_WEBHOOK_SECRET=your-webhook-secret
# After `modal deploy`, this is the URL printed in the terminal
# e.g. https://your-user--alphogenai-v2-webhook.modal.run
MODAL_WEBHOOK_URL=https://your-modal-webhook-url.modal.run
# URL for flushing engine registry + costs cache on Modal side.
# Typically: same host as MODAL_WEBHOOK_URL but path = /flush-cache
MODAL_FLUSH_CACHE_URL=https://your-modal-webhook-url.modal.run/flush-cache

# ===========================================
# Video Generation
# ===========================================
VIDEO_DURATION_SEC=8
VIDEO_FPS=24
VIDEO_RESOLUTION=1280x720

# ===========================================
# Cloudflare R2 (used by worker for video upload)
# ===========================================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=alphogenai-assets
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ===========================================
# Stripe (monetization)
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# Internal cost tracking UI (admin-only)
# ===========================================
# Set to "true" to show engine + estimated cost on job pages (admin only)
NEXT_PUBLIC_SHOW_COST_TRACKING_UI=false
# Comma-separated list of admin emails
NEXT_PUBLIC_ADMIN_EMAILS=

# ===========================================
# Engine secrets encryption (admin model management)
# ===========================================
# Generate with: openssl rand -hex 32
# Must be 64 hex characters (32 bytes / 256 bits)
ENGINE_SECRETS_KEY=

# ===========================================
# Social Media OAuth (for auto-posting)
# ===========================================
# Google (YouTube) — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# TikTok — developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Instagram (Meta/Facebook) — developers.facebook.com
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ===========================================
# Sentry (error monitoring — optional)
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ===========================================
# Resend (email notifications)
# ===========================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=AlphoGenAI <noreply@alphogenai.com>

# ===========================================
# Seedance / Kie.ai (pro/premium engine)
# ===========================================
# API key from https://kie.ai/api-key
KIE_API_KEY=your-kie-api-key
# Set to "true" in Modal secrets to activate Seedance for pro/premium users
ENABLE_SEEDANCE=false

# ===========================================
# Optional
# ===========================================
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
